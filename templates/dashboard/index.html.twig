{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
{% set last_logs = last_logs ?? {} %}
{% set author_names = author_names ?? {} %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Tableau de bord</h1>
</div>

{% if is_chef is defined and is_chef %}
    {# Vue Chef de service #}
    {% if current_user %}
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-subtitle text-muted mb-1">Mon solde de congés</h6>
                    <div class="d-flex align-items-end gap-2">
                        <span class="display-6 fw-bold text-primary">{{ current_user.leaveBalance.value|round(2) }}</span>
                        <span class="text-muted mb-1">h</span>
                    </div>
                    <div class="mt-2">
                        <a href="{{ path('app_leave_new', {type: 'CONGE'}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-plus-circle me-1"></i>Nouvelle demande
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-subtitle text-muted mb-1">Mon solde RTT</h6>
                    <div class="d-flex align-items-end gap-2">
                        <span class="display-6 fw-bold text-cyan">{{ current_user.rttBalance.value|round(1) }}</span>
                        <span class="text-muted mb-1">jour(s)</span>
                    </div>
                    <div class="mt-2">
                        <a href="{{ path('app_leave_new', {type: 'RTT'}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-plus-circle me-1"></i>Nouvelle demande
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-subtitle text-muted mb-1">Mon solde heures sup.</h6>
                    <div class="d-flex align-items-end gap-2">
                        <span class="display-6 fw-bold text-orange">{{ current_user.heureSupBalance.value|round(2) }}</span>
                        <span class="text-muted mb-1">h</span>
                    </div>
                    <div class="mt-2">
                        <a href="{{ path('app_leave_new', {type: 'HEURE_SUP'}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-plus-circle me-1"></i>Nouvelle demande
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
    <div class="card shadow-sm border-warning border-2">
        <div class="card-header d-flex justify-content-between align-items-center text-bg-warning">
            <span class="fw-semibold"><i class="bi bi-person-check me-1"></i>Demandes en attente dans mon service</span>
            <span class="badge bg-dark bg-opacity-25">{{ pending_leaves|length }}</span>
        </div>
        {% if pending_leaves is empty %}
            <div class="card-body text-muted text-center py-4">
                <i class="bi bi-check-circle fs-3 text-success d-block mb-2"></i>
                Aucune demande en attente dans votre service.
            </div>
        {% else %}
            <div class="p-3 pb-0">
                <input type="search" class="form-control form-control-sm" placeholder="Rechercher…" id="searchChefPending" oninput="filterTable(this,'chefPendingTable')">
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="chefPendingTable">
                    <thead class="table-warning">
                        <tr><th>Agent</th><th>Type</th><th>Période</th><th>Durée</th><th>Soumis le</th></tr>
                    </thead>
                    <tbody>
                        {% for leave in pending_leaves %}
                        <tr class="clickable-row" data-href="{{ path('app_leave_show', {id: leave.id}) }}" style="cursor:pointer">
                            <td>{{ agent_names[leave.userId] ?? leave.userId }}</td>
                            <td>{{ leave.type.label() }}</td>
                            <td>{{ leave.dateDebutFormatted|date('d/m/Y') }} → {{ leave.dateFinFormatted|date('d/m/Y') }}</td>
                            <td>{{ leave.type.value == 'RTT' ? (leave.heuresValue == 0.5 ? '½ j' : leave.heuresValue|round(0) ~ ' j') : (leave.heuresValue|round(2) ~ ' h') }}</td>
                            <td>{{ leave.createdAt|date('d/m/Y') }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
    <div class="mt-3 d-flex gap-2 flex-wrap">
        <a href="{{ path('app_leave_list') }}" class="btn btn-outline-secondary">
            <i class="bi bi-list-ul me-1"></i>Toutes les demandes de mon service
        </a>
        {% if recap_agents is defined and recap_agents is not empty %}
        <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#recapModal">
            <i class="bi bi-file-earmark-bar-graph me-1"></i>Récapitulatif des soldes
        </button>
        {% endif %}
    </div>

    {% if recap_agents is defined and recap_agents is not empty %}
    <div class="modal fade" id="recapModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-bar-graph me-1"></i>Récapitulatif des soldes</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="recapAgent" class="form-label fw-semibold">Agent</label>
                        <select id="recapAgent" class="form-select">
                            <option value="">— Tout mon service —</option>
                            {% for agent in recap_agents %}
                            <option value="{{ agent.id }}">{{ agent.nomComplet ?? agent.username }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-primary"
                            onclick="window.location.href='{{ path('app_agents_recap_pdf') }}' + (document.getElementById('recapAgent').value ? '?userId=' + document.getElementById('recapAgent').value : '')">
                        <i class="bi bi-download me-1"></i>Télécharger le PDF
                    </button>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

{% elseif is_granted('ROLE_RH') %}
    {# Vue RH #}
    {% if current_user %}
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-subtitle text-muted mb-1">Mon solde de congés</h6>
                    <div class="d-flex align-items-end gap-2">
                        <span class="display-6 fw-bold text-primary">{{ current_user.leaveBalance.value|round(2) }}</span>
                        <span class="text-muted mb-1">h</span>
                    </div>
                    <div class="mt-2">
                        <a href="{{ path('app_leave_new', {type: 'CONGE'}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-plus-circle me-1"></i>Nouvelle demande
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-subtitle text-muted mb-1">Mon solde RTT</h6>
                    <div class="d-flex align-items-end gap-2">
                        <span class="display-6 fw-bold text-cyan">{{ current_user.rttBalance.value|round(1) }}</span>
                        <span class="text-muted mb-1">jour(s)</span>
                    </div>
                    <div class="mt-2">
                        <a href="{{ path('app_leave_new', {type: 'RTT'}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-plus-circle me-1"></i>Nouvelle demande
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-subtitle text-muted mb-1">Mon solde heures sup.</h6>
                    <div class="d-flex align-items-end gap-2">
                        <span class="display-6 fw-bold text-orange">{{ current_user.heureSupBalance.value|round(2) }}</span>
                        <span class="text-muted mb-1">h</span>
                    </div>
                    <div class="mt-2">
                        <a href="{{ path('app_leave_new', {type: 'HEURE_SUP'}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-plus-circle me-1"></i>Nouvelle demande
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
    <div class="card shadow-sm border-warning border-2">
        <div class="card-header d-flex justify-content-between align-items-center text-bg-warning">
            <span class="fw-semibold"><i class="bi bi-clock-history me-1"></i>Demandes en attente</span>
            <span class="badge bg-dark bg-opacity-25">{{ pending_leaves|length }}</span>
        </div>
        {% if pending_leaves is empty %}
            <div class="card-body text-muted text-center py-4">
                <i class="bi bi-check-circle fs-3 text-success d-block mb-2"></i>
                Aucune demande en attente.
            </div>
        {% else %}
            <div class="p-3 pb-0">
                <input type="search" class="form-control form-control-sm" placeholder="Rechercher…" id="searchRhPending" oninput="filterTable(this,'rhPendingTable')">
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="rhPendingTable">
                    <thead class="table-warning">
                        <tr>
                            <th>Agent</th>
                            <th>Type</th>
                            <th>Période</th>
                            <th>Durée</th>
                            <th>Soumis le</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for leave in pending_leaves %}
                        <tr class="clickable-row" data-href="{{ path('app_leave_show', {id: leave.id}) }}" style="cursor:pointer">
                            <td>{{ agent_names[leave.userId] ?? leave.userId }}</td>
                            <td>{{ leave.type.label() }}</td>
                            <td>{{ leave.dateDebutFormatted|date('d/m/Y') }} → {{ leave.dateFinFormatted|date('d/m/Y') }}</td>
                            <td>
                                {% if leave.type.value == 'RTT' %}
                                    {{ leave.heuresValue == 0.5 ? '½ jour' : leave.heuresValue|round(0) ~ ' jour' ~ (leave.heuresValue > 1 ? 's' : '') }}
                                {% else %}
                                    {{ leave.heuresValue|round(2) }} h
                                {% endif %}
                            </td>
                            <td>{{ leave.createdAt|date('d/m/Y') }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    {% if validated_chef_leaves is defined and validated_chef_leaves|length > 0 %}
    <div class="card shadow-sm mt-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold"><i class="bi bi-person-check me-1"></i>Validées par le chef de service — en attente de validation RH</span>
            <span class="badge bg-info text-dark">{{ validated_chef_leaves|length }}</span>
        </div>
        <div class="p-3 pb-0">
            <input type="search" class="form-control form-control-sm" placeholder="Rechercher…" id="searchRhValidated" oninput="filterTable(this,'rhValidatedTable')">
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="rhValidatedTable">
                <thead class="table-light">
                    <tr><th>Agent</th><th>Type</th><th>Période</th><th>Durée</th></tr>
                </thead>
                <tbody>
                    {% for leave in validated_chef_leaves %}
                    <tr class="clickable-row" data-href="{{ path('app_leave_show', {id: leave.id}) }}" style="cursor:pointer">
                        <td>{{ agent_names[leave.userId] ?? leave.userId }}</td>
                        <td>{{ leave.type.label() }}</td>
                        <td>{{ leave.dateDebutFormatted|date('d/m/Y') }} → {{ leave.dateFinFormatted|date('d/m/Y') }}</td>
                        <td>{{ leave.type.value == 'RTT' ? (leave.heuresValue == 0.5 ? '½ j' : leave.heuresValue|round(0) ~ ' j') : (leave.heuresValue|round(2) ~ ' h') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    <div class="mt-3 d-flex gap-2 flex-wrap">
        <a href="{{ path('app_leave_list', {type: 'ALL'}) }}" class="btn btn-outline-secondary">
            <i class="bi bi-list-ul me-1"></i>Toutes les demandes
        </a>
        <a href="{{ path('app_agents_list') }}" class="btn btn-outline-secondary">
            <i class="bi bi-people me-1"></i>Gérer les utilisateurs
        </a>
        {% if recap_agents is defined and recap_agents is not empty %}
        <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#recapModal">
            <i class="bi bi-file-earmark-bar-graph me-1"></i>Récapitulatif des soldes
        </button>
        {% endif %}
    </div>

    {% if recap_agents is defined and recap_agents is not empty %}
    <div class="modal fade" id="recapModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-bar-graph me-1"></i>Récapitulatif des soldes</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="recapAgent" class="form-label fw-semibold">Agent</label>
                        <select id="recapAgent" class="form-select">
                            <option value="">— Tous les agents —</option>
                            {% for agent in recap_agents %}
                            <option value="{{ agent.id }}">{{ agent.nomComplet ?? agent.username }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-primary"
                            onclick="window.location.href='{{ path('app_agents_recap_pdf') }}' + (document.getElementById('recapAgent').value ? '?userId=' + document.getElementById('recapAgent').value : '')">
                        <i class="bi bi-download me-1"></i>Télécharger le PDF
                    </button>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

{% else %}
    {# Vue Agent #}
    {% if current_user %}
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-subtitle text-muted mb-1">Solde de congés</h6>
                    <div class="d-flex align-items-end gap-2">
                        <span class="display-6 fw-bold text-primary">{{ current_user.leaveBalance.value|round(2) }}</span>
                        <span class="text-muted mb-1">h</span>
                    </div>
                 
                    <div class="mt-2">
                        <a href="{{ path('app_leave_new', {type: 'CONGE'}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-plus-circle me-1"></i>Nouvelle demande
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-subtitle text-muted mb-1">Solde RTT</h6>
                    <div class="d-flex align-items-end gap-2">
                        <span class="display-6 fw-bold text-cyan">{{ current_user.rttBalance.value|round(1) }}</span>
                        <span class="text-muted mb-1">jour(s)</span>
                    </div>
                    <div class="mt-2">
                        <a href="{{ path('app_leave_new', {type: 'RTT'}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-plus-circle me-1"></i>Nouvelle demande
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-subtitle text-muted mb-1">Solde heures sup.</h6>
                    <div class="d-flex align-items-end gap-2">
                        <span class="display-6 fw-bold text-orange">{{ current_user.heureSupBalance.value|round(2) }}</span>
                        <span class="text-muted mb-1">h</span>
                    </div>
                    <div class="mt-2">
                        <a href="{{ path('app_leave_new', {type: 'HEURE_SUP'}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-plus-circle me-1"></i>Nouvelle demande
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    <div class="card shadow-sm">
        <div class="card-header fw-semibold">
            <i class="bi bi-calendar3 me-1"></i>Mes dernières demandes
        </div>
        {% if my_leaves is empty %}
            <div class="card-body text-muted text-center py-4">Aucune demande pour l'instant.</div>
        {% else %}
            <div class="p-3 pb-0">
                <input type="search" class="form-control form-control-sm" placeholder="Rechercher…" id="searchMyLeaves" oninput="filterTable(this,'myLeavesTable')">
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="myLeavesTable">
                    <thead class="table-light">
                        <tr>
                            <th>Type</th>
                            <th>Période</th>
                            <th>Durée</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for leave in my_leaves %}
                        <tr class="clickable-row" data-href="{{ path('app_leave_show', {id: leave.id}) }}" style="cursor:pointer">
                            <td>{{ leave.type.label() }}</td>
                            <td>{{ leave.dateDebutFormatted|date('d/m/Y') }} → {{ leave.dateFinFormatted|date('d/m/Y') }}</td>
                            <td>
                                {% if leave.type.value == 'RTT' %}
                                    {{ leave.heuresValue == 0.5 ? '½ jour' : leave.heuresValue|round(0) ~ ' jour' ~ (leave.heuresValue > 1 ? 's' : '') }}
                                {% else %}
                                    {{ leave.heuresValue|round(2) }} h
                                {% endif %}
                            </td>
                            <td>
                                {% include 'components/leave_status_badge.html.twig' with {leave: leave} %}
                                {% if leave.statutValue in ['APPROVED', 'REJECTED', 'VALIDATED_CHEF'] %}
                                    {% set log = last_logs[leave.id] ?? null %}
                                    {% if log and log.auteurId %}
                                        <br><small class="text-muted">par {{ author_names[log.auteurId] ?? log.auteurId }}</small>
                                    {% endif %}
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
        <div class="card-footer">
            <a href="{{ path('app_leave_list') }}" class="btn btn-sm btn-outline-primary">Voir toutes mes demandes</a>
        </div>
    </div>
{% endif %}
{% endblock %}

{% block javascripts %}
<script>
function filterTable(input, tableId) {
    var q = input.value.toLowerCase();
    document.querySelectorAll('#' + tableId + ' tbody tr').forEach(function(row) {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}

document.querySelectorAll('.clickable-row').forEach(function(row) {
    row.addEventListener('click', function(e) {
        if (e.target.closest('a, button')) return;
        window.location.href = row.dataset.href;
    });
});
</script>
{% endblock %}
