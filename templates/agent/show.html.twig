{% extends 'base.html.twig' %}

{% block title %}{{ user.nomComplet ?? user.username }}{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    {% if is_granted('ROLE_RH') %}
        <a href="{{ path('app_agents_list') }}" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
    {% endif %}
    <h1 class="h3 mb-0 flex-grow-1">{{ user.nomComplet ?? user.username }}</h1>
    {% if is_granted('ROLE_RH') %}
        <a href="{{ path('app_admin_users_edit', {id: user.id}) }}" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-pencil me-1"></i>Modifier
        </a>
        <form method="post" action="{{ path('app_agents_delete', {id: user.id}) }}"
              onsubmit="return confirm('Supprimer définitivement {{ user.nomComplet ?? user.username }} ainsi que toutes ses demandes de congé ?')">
            <input type="hidden" name="_token" value="{{ csrf_token('agent_delete_' ~ user.id) }}">
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash me-1"></i>Supprimer
            </button>
        </form>
    {% endif %}
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold"><i class="bi bi-person me-1"></i>Informations</div>
            <ul class="list-group list-group-flush">
                {% if user.nom %}
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Nom</span>
                    <span>{{ user.nom }}</span>
                </li>
                {% endif %}
                {% if user.prenom %}
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Prénom</span>
                    <span>{{ user.prenom }}</span>
                </li>
                {% endif %}
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Identifiant</span>
                    <span>{{ user.username }}</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">E-mail</span>
                    <span>{{ user.email }}</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span class="text-muted">Solde congés</span>
                    <span class="fw-bold fs-5 text-primary">{{ user.leaveBalance.value|round(2) }} h</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span class="text-muted">Solde RTT</span>
                    <span class="fw-bold fs-5 text-info">{{ user.rttBalance.value|round(2) }} h</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span class="text-muted">Solde heures sup.</span>
                    <span class="fw-bold fs-5 text-warning">{{ user.heureSupBalance.value|round(2) }} h</span>
                </li>
            </ul>
        </div>

        {% if is_granted('ROLE_RH') %}
        <div class="card shadow-sm mt-3">
            <div class="card-header fw-semibold"><i class="bi bi-pencil me-1"></i>Modifier les soldes</div>
            <div class="card-body d-flex flex-column gap-2">
                <form method="post" action="{{ path('app_agents_balance', {id: user.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('balance_' ~ user.id) }}">
                    <input type="hidden" name="balanceType" value="CONGE">
                    <label class="form-label small fw-semibold mb-1">Congés</label>
                    <div class="input-group">
                        <input type="number" name="leaveBalanceHours" class="form-control"
                               value="{{ user.leaveBalance.value }}" min="0" step="0.5" required>
                        <span class="input-group-text">h</span>
                        <button class="btn btn-outline-primary" type="submit">Mettre à jour</button>
                    </div>
                </form>
                <form method="post" action="{{ path('app_agents_balance', {id: user.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('balance_' ~ user.id) }}">
                    <input type="hidden" name="balanceType" value="RTT">
                    <label class="form-label small fw-semibold mb-1">RTT</label>
                    <div class="input-group">
                        <input type="number" name="leaveBalanceHours" class="form-control"
                               value="{{ user.rttBalance.value }}" min="0" step="0.5" required>
                        <span class="input-group-text">h</span>
                        <button class="btn btn-outline-info" type="submit">Mettre à jour</button>
                    </div>
                </form>
                <form method="post" action="{{ path('app_agents_balance', {id: user.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('balance_' ~ user.id) }}">
                    <input type="hidden" name="balanceType" value="HEURE_SUP">
                    <label class="form-label small fw-semibold mb-1">Heures sup.</label>
                    <div class="input-group">
                        <input type="number" name="leaveBalanceHours" class="form-control"
                               value="{{ user.heureSupBalance.value }}" min="0" step="0.5" required>
                        <span class="input-group-text">h</span>
                        <button class="btn btn-outline-warning" type="submit">Mettre à jour</button>
                    </div>
                </form>
            </div>
        </div>
        {% endif %}
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold"><i class="bi bi-calendar3 me-1"></i>Demandes de congé</div>
            <div class="card-body text-center text-muted py-4">
                <a href="{{ path('app_leave_list') }}{% if is_granted('ROLE_RH') %}?userId={{ user.id }}{% endif %}" class="btn btn-outline-secondary">
                    <i class="bi bi-list-ul me-1"></i>Voir les demandes
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
