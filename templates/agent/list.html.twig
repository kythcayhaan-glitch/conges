{% extends 'base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-people me-2"></i>Utilisateurs</h1>
    <a href="{{ path('app_admin_users_new') }}" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Nouvel utilisateur
    </a>
</div>

<div class="card shadow-sm">
    {% if users is empty %}
        <div class="card-body text-muted text-center py-5">Aucun utilisateur enregistré.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>N° service</th>
                        <th>Nom</th>
                        <th>Identifiant</th>
                        <th>E-mail</th>
                        <th class="text-end">Congés (Heures)</th>
                        <th class="text-end">RTT (Jours)</th>
                        <th class="text-end">Heures supplémentaires. (Heures)</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td>
                            {% if user.serviceNumbers is not empty %}
                                {% for sn in user.serviceNumbers %}
                                    <span class="badge bg-secondary font-monospace">{{ sn }}</span>
                                {% endfor %}
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td>{{ user.nomComplet ?? '—' }}</td>
                        <td>{{ user.username }}</td>
                        <td>{{ user.email }}</td>
                        <td class="text-end fw-semibold text-primary">{{ user.leaveBalance.value|round(2) }}</td>
                        <td class="text-end fw-semibold text-info">{{ user.rttBalance.value|round(2) }}</td>
                        <td class="text-end fw-semibold text-warning">{{ user.heureSupBalance.value|round(2) }}</td>
                        <td class="text-end">
                            <a href="{{ path('app_agents_show', {id: user.id}) }}" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
