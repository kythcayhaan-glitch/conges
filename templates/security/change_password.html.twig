{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-person-gear me-2"></i>Mon compte</h1>
</div>

<div class="card shadow-sm" style="max-width:480px">
    <div class="card-header fw-semibold">
        <i class="bi bi-lock me-1"></i>Changer de mot de passe
    </div>
    <div class="card-body">
        <form method="post" action="{{ path('app_account_password') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('change_password') }}">

            <div class="mb-3">
                <label for="current_password" class="form-label fw-semibold">Mot de passe actuel <span class="text-danger">*</span></label>
                <input type="password" id="current_password" name="current_password"
                       class="form-control" autocomplete="current-password" required>
            </div>
            <div class="mb-3">
                <label for="new_password" class="form-label fw-semibold">Nouveau mot de passe <span class="text-danger">*</span></label>
                <input type="password" id="new_password" name="new_password"
                       class="form-control" autocomplete="new-password" minlength="8" required>
                <div class="form-text">8 caractères minimum.</div>
            </div>
            <div class="mb-4">
                <label for="confirmation" class="form-label fw-semibold">Confirmer le nouveau mot de passe <span class="text-danger">*</span></label>
                <input type="password" id="confirmation" name="confirmation"
                       class="form-control" autocomplete="new-password" minlength="8" required>
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Enregistrer
            </button>
        </form>
    </div>
</div>
{% endblock %}
