{% extends 'base.html.twig' %}

{% block title %}Administration — Utilisateurs{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-shield-lock me-2"></i>Gestion des utilisateurs</h1>
    <a href="{{ path('app_admin_users_new') }}" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Nouvel utilisateur
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>N° service</th>
                    <th>Identifiant</th>
                    <th>Prénom nom</th>
                    <th>E-mail</th>
                    <th>Rôles</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                {% set is_self = user.username == app.user.userIdentifier %}
                <tr class="{{ is_self ? 'table-secondary' : '' }}">
                    <td>
                        {% if user.serviceNumbers is not empty %}
                            {% for sn in user.serviceNumbers %}
                                <span class="badge bg-secondary font-monospace">{{ sn }}</span>
                            {% endfor %}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>
                        <span class="fw-semibold">{{ user.username }}</span>
                        {% if is_self %}
                            <small class="text-muted ms-1"><i class="bi bi-person-fill"></i> Vous</small>
                        {% endif %}
					
					</td>
                    <td class="text-muted small">{{ user.prenom }} {{ user.nom }}</td>
                    
                    <td class="text-muted small">{{ user.email }}</td>
                    <td>
                        {% for role in user.roles %}
                            {% if role == 'ROLE_ADMIN' %}
                                <span class="badge bg-danger me-1">Admin</span>
                            {% elseif role == 'ROLE_RH' %}
                                <span class="badge bg-primary me-1">RH</span>
                            {% elseif role == 'ROLE_CHEF_SERVICE' %}
                                <span class="badge bg-info text-dark me-1">Chef service</span>
                            {% elseif role == 'ROLE_AGENT' %}
                                <span class="badge bg-secondary me-1">Agent</span>
                            {% endif %}
                        {% endfor %}
                    </td>
                    <td class="text-end">
                        <a href="{{ path('app_admin_users_edit', {id: user.id}) }}"
                           class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i>Modifier
                        </a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <small class="text-muted">
        <i class="bi bi-info-circle me-1"></i>
        <strong>Agent</strong> : accès à ses propres congés. &nbsp;
        <strong>RH</strong> : gestion de tous les agents et congés. &nbsp;
        <strong>Admin</strong> : accès à cette page.
    </small>
</div>
{% endblock %}
