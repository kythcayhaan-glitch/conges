{% extends 'base.html.twig' %}

{% block title %}Nouvel utilisateur{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('app_admin_users') }}" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="h3 mb-0"><i class="bi bi-person-plus me-2"></i>Nouvel utilisateur</h1>
</div>

<div class="card shadow-sm" style="max-width:560px">
    <div class="card-body">
        <form method="post" action="{{ path('app_admin_users_new') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('admin_user_new') }}">

            <h6 class="text-muted fw-semibold mb-3 text-uppercase" style="font-size:.75rem;letter-spacing:.05em">Compte</h6>

            <div class="mb-3">
                <label for="username" class="form-label fw-semibold">Identifiant <span class="text-danger">*</span></label>
                <input type="text" id="username" name="username" class="form-control"
                       value="{{ form_data.username ?? '' }}" autocomplete="off"
                       pattern="[a-zA-Z0-9._-]+" required>
                <div class="form-text">Ex : nom.prénom — utilisé pour la connexion.</div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label fw-semibold">Adresse e-mail <span class="text-danger">*</span></label>
                <input type="email" id="email" name="email" class="form-control"
                       value="{{ form_data.email ?? '' }}" autocomplete="off" required>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label fw-semibold">Mot de passe initial <span class="text-danger">*</span></label>
                <input type="password" id="password" name="password" class="form-control"
                       autocomplete="new-password" minlength="8" required>
                <div class="form-text">8 caractères minimum.</div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Rôles</label>
                <div class="d-flex gap-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="role_agent"
                               name="roles[]" value="ROLE_AGENT" checked disabled>
                        <label class="form-check-label text-muted" for="role_agent">Agent <small>(toujours actif)</small></label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="role_chef"
                               name="roles[]" value="ROLE_CHEF_SERVICE"
                               {{ (form_data.roles is defined and 'ROLE_CHEF_SERVICE' in form_data.roles) ? 'checked' : '' }}>
                        <label class="form-check-label" for="role_chef">Chef de service</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="role_rh"
                               name="roles[]" value="ROLE_RH"
                               {{ (form_data.roles is defined and 'ROLE_RH' in form_data.roles) ? 'checked' : '' }}>
                        <label class="form-check-label" for="role_rh">Responsable RH</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="role_admin"
                               name="roles[]" value="ROLE_ADMIN"
                               {{ (form_data.roles is defined and 'ROLE_ADMIN' in form_data.roles) ? 'checked' : '' }}>
                        <label class="form-check-label" for="role_admin">Administrateur</label>
                    </div>
                </div>
            </div>

            <hr>
            <h6 class="text-muted fw-semibold mb-3 text-uppercase" style="font-size:.75rem;letter-spacing:.05em">
                Profil agent <small class="text-muted fw-normal">(optionnel)</small>
            </h6>

            <div class="row g-3 mb-3">
                <div class="col">
                    <label for="nom" class="form-label fw-semibold">Nom</label>
                    <input type="text" id="nom" name="nom" class="form-control"
                           value="{{ form_data.nom ?? '' }}">
                </div>
                <div class="col">
                    <label for="prenom" class="form-label fw-semibold">Prénom</label>
                    <input type="text" id="prenom" name="prenom" class="form-control"
                           value="{{ form_data.prenom ?? '' }}">
                </div>
            </div>

            <div class="mb-3" style="max-width:260px">
                <label for="serviceNumbers" class="form-label fw-semibold">N° de service(s)</label>
                <input type="text" id="serviceNumbers" name="serviceNumbers" class="form-control font-monospace"
                       value="{{ form_data.serviceNumbers ?? '' }}"
                       placeholder="ex : 03, 11">
                <div class="form-text">Un ou plusieurs numéros séparés par des virgules (ex : 03, 11).</div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-sm-4">
                    <label for="leaveBalanceHours" class="form-label fw-semibold">Solde congés</label>
                    <div class="input-group">
                        <input type="number" id="leaveBalanceHours" name="leaveBalanceHours" class="form-control"
                               value="{{ form_data.leaveBalanceHours ?? '0' }}" min="0" step="0.25">
                        <span class="input-group-text">h</span>
                    </div>
                </div>
                <div class="col-sm-4">
                    <label for="rttBalanceHours" class="form-label fw-semibold">Solde RTT</label>
                    <div class="input-group">
                        <input type="number" id="rttBalanceHours" name="rttBalanceHours" class="form-control"
                               value="{{ form_data.rttBalanceHours ?? '0' }}" min="0" step="0.25">
                        <span class="input-group-text">j</span>
                    </div>
                </div>
                <div class="col-sm-4">
                    <label for="heureSupBalanceHours" class="form-label fw-semibold">Solde heures sup.</label>
                    <div class="input-group">
                        <input type="number" id="heureSupBalanceHours" name="heureSupBalanceHours" class="form-control"
                               value="{{ form_data.heureSupBalanceHours ?? '0' }}" min="0" step="0.25">
                        <span class="input-group-text">h</span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Créer
                </button>
                <a href="{{ path('app_admin_users') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
