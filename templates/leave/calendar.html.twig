{% extends 'base.html.twig' %}
{% block title %}Calendrier des absences{% endblock %}

{% block stylesheets %}
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-calendar3-week me-2"></i>Calendrier des absences</h1>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap align-items-center">
    <span><span style="display:inline-block;width:14px;height:14px;background:#0d6efd;border-radius:3px;vertical-align:middle"></span> Congé</span>
    <span><span style="display:inline-block;width:14px;height:14px;background:#20c997;border-radius:3px;vertical-align:middle"></span> RTT</span>
    <span><span style="display:inline-block;width:14px;height:14px;background:#fd7e14;border-radius:3px;vertical-align:middle"></span> Heures sup.</span>
    <span class="text-muted small ms-2">Opacité : plein = approuvé · moyen = validé chef · clair = en attente</span>
    <span class="text-muted small">— Cliquez sur une date pour créer une demande</span>
</div>

<div class="card shadow-sm p-3">
    <div id="calendar"></div>
</div>

{# Modal choix du type de demande #}
<div class="modal fade" id="newLeaveModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-1"></i>Nouvelle demande</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-muted mb-3" id="modalDateLabel"></p>
                <div class="d-grid gap-2">
                    <a id="btnConge"    href="#" class="btn btn-primary"><i class="bi bi-calendar3 me-1"></i>Congé</a>
                    <a id="btnRtt"      href="#" class="btn btn-outline-info"><i class="bi bi-clock me-1"></i>RTT</a>
                    <a id="btnHeureSup" href="#" class="btn btn-outline-warning"><i class="bi bi-hourglass-split me-1"></i>Heures supplémentaires</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var baseUrl   = {{ path('app_leave_new')|json_encode|raw }};
    var modal     = new bootstrap.Modal(document.getElementById('newLeaveModal'));
    var dateLabel = document.getElementById('modalDateLabel');

    function setModalDate(dateStr) {
        var d = new Date(dateStr + 'T12:00:00');
        dateLabel.textContent = d.toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'long', year:'numeric'});
        document.getElementById('btnConge').href    = baseUrl + '?type=CONGE&date='     + dateStr;
        document.getElementById('btnRtt').href      = baseUrl + '?type=RTT&date='       + dateStr;
        document.getElementById('btnHeureSup').href = baseUrl + '?type=HEURE_SUP&date=' + dateStr;
    }

    var calendarEl = document.getElementById('calendar');
    var calendar   = new FullCalendar.Calendar(calendarEl, {
        locale:        'fr',
        initialView:   'dayGridMonth',
        headerToolbar: {
            left:   'prev,next today',
            center: 'title',
            right:  'dayGridMonth,timeGridWeek,listMonth'
        },
        buttonText: {
            today:     "Aujourd'hui",
            month:     'Mois',
            week:      'Semaine',
            list:      'Liste'
        },
        selectable:  true,
        events:      {{ events|json_encode|raw }},
        dateClick:   function(info) {
            setModalDate(info.dateStr);
            modal.show();
        },
        eventClick:  function(info) {
            info.jsEvent.preventDefault();
            if (info.event.url) {
                window.location.href = info.event.url;
            }
        },
        eventDidMount: function(info) {
            info.el.title = info.event.title;
        },
        height:         'auto',
        fixedWeekCount: false,
    });
    calendar.render();
});
</script>
{% endblock %}
