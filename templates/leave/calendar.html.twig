{% extends 'base.html.twig' %}
{% block title %}Calendrier des absences{% endblock %}

{% block stylesheets %}
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet">
<style>
/* ── Conteneur général ── */
#calendar { font-size: 11px; }

/* ── En-têtes des mois ── */
.fc .fc-multimonth-title {
    background: #1565c0;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    padding: 5px 0;
}

/* ── En-têtes jours de la semaine ── */
.fc .fc-col-header-cell {
    background: #e3f0ff;
    font-size: 10px;
    font-weight: 700;
    color: #1565c0;
    text-transform: uppercase;
    padding: 2px 0;
}
/* Samedi */
.fc .fc-col-header-cell:nth-child(7) { background: #f0f0f0; color: #555; }
/* Dimanche */
.fc .fc-col-header-cell:nth-child(1) { background: #fde8e8; color: #c0392b; }

/* ── Cellules des jours ── */
.fc .fc-daygrid-day { padding: 0 !important; }
.fc .fc-daygrid-day-frame { min-height: 52px; }
.fc .fc-daygrid-day-number {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 4px;
    line-height: 1.2;
}

/* ── Samedi ── */
.fc .fc-day-sat { background: #f7f7f7; }
.fc .fc-day-sat .fc-daygrid-day-number { color: #666; }

/* ── Dimanche ── */
.fc .fc-day-sun { background: #fff5f5; }
.fc .fc-day-sun .fc-daygrid-day-number { color: #c0392b; font-weight: 700; }

/* ── Aujourd'hui ── */
.fc .fc-day-today { background: #fffde7 !important; }
.fc .fc-day-today .fc-daygrid-day-number {
    background: #f9a825;
    color: #fff;
    border-radius: 50%;
    width: 20px; height: 20px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px;
}

/* ── Numéros de semaine ── */
.fc .fc-daygrid-week-number {
    background: #1565c0;
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    border-radius: 0;
    min-width: 18px;
    padding: 2px 3px;
}

/* ── Événements ── */
.fc-event { font-size: 10px; border-radius: 2px; padding: 1px 3px; }
.fc-event-title { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* ── Vue annuelle : grille 4 colonnes × 3 lignes ── */
.fc-multimonth-multicol .fc-multimonth-month { min-width: 0; }

/* ── Toolbar ── */
.fc .fc-toolbar-title { font-size: 16px; font-weight: 700; color: #1565c0; }
.fc .fc-button-primary {
    background: #1565c0;
    border-color: #1565c0;
    font-size: 12px;
}
.fc .fc-button-primary:hover,
.fc .fc-button-primary:not(:disabled).fc-button-active {
    background: #0d47a1;
    border-color: #0d47a1;
}
</style>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-calendar3-week me-2"></i>Calendrier des absences</h1>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap align-items-center">
    <strong class="small text-muted me-1">Type :</strong>
    <span><span style="display:inline-block;width:13px;height:13px;background:#0d6efd;border-radius:2px;vertical-align:middle"></span> Congé</span>
    <span><span style="display:inline-block;width:13px;height:13px;background:#20c997;border-radius:2px;vertical-align:middle"></span> RTT</span>
    <span><span style="display:inline-block;width:13px;height:13px;background:#fd7e14;border-radius:2px;vertical-align:middle"></span> Heures sup.</span>
    <span class="text-muted">|</span>
    <strong class="small text-muted me-1">Statut :</strong>
    <span><span style="display:inline-block;width:13px;height:13px;background:#e53935;border-radius:2px;vertical-align:middle"></span> En attente</span>
    <span><span style="display:inline-block;width:13px;height:13px;background:#9e9e9e;border-radius:2px;vertical-align:middle"></span> Validé chef</span>
    <span><span style="display:inline-block;width:13px;height:13px;background:#0d6efd;border-radius:2px;vertical-align:middle"></span> Approuvé</span>
    <span class="text-muted small">· Cliquez ou glissez pour créer une demande</span>
</div>

<div class="card shadow-sm p-2">
    <div id="calendar"></div>
</div>

{# Modal choix du type de demande #}
<div class="modal fade" id="newLeaveModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-1"></i>Nouvelle demande</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-muted mb-3" id="modalDateLabel"></p>
                <div class="d-grid gap-2">
                    <a id="btnConge"    href="#" class="btn btn-primary"><i class="bi bi-calendar3 me-1"></i>Congé</a>
                    <a id="btnRtt"      href="#" class="btn btn-outline-info"><i class="bi bi-clock me-1"></i>RTT</a>
                    <a id="btnHeureSup" href="#" class="btn btn-outline-warning"><i class="bi bi-hourglass-split me-1"></i>Heures supplémentaires</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/locales/fr.global.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var baseUrl   = {{ path('app_leave_new')|json_encode|raw }};
    var modal     = new bootstrap.Modal(document.getElementById('newLeaveModal'));
    var dateLabel = document.getElementById('modalDateLabel');

    var fmt = {day:'numeric', month:'long', year:'numeric'};

    function setModalRange(startStr, endStr) {
        var start = new Date(startStr + 'T12:00:00');
        var end   = new Date(endStr   + 'T12:00:00');
        if (startStr === endStr) {
            dateLabel.textContent = start.toLocaleDateString('fr-FR', {weekday:'long', ...fmt});
        } else {
            dateLabel.textContent = start.toLocaleDateString('fr-FR', fmt) + ' → ' + end.toLocaleDateString('fr-FR', fmt);
        }
        var params = '&dateDebut=' + startStr + '&dateFin=' + endStr;
        document.getElementById('btnConge').href    = baseUrl + '?type=CONGE'     + params;
        document.getElementById('btnRtt').href      = baseUrl + '?type=RTT'       + params;
        document.getElementById('btnHeureSup').href = baseUrl + '?type=HEURE_SUP' + params;
    }

    var calendarEl = document.getElementById('calendar');
    var calendar   = new FullCalendar.Calendar(calendarEl, {
        locale:          'fr',
        initialView:     'multiMonthYear',
        weekNumbers:     true,
        weekNumberFormat: { week: 'numeric' },
        firstDay:        1,
        multiMonthMaxColumns: 4,
        headerToolbar: {
            left:   'prev,next today',
            center: 'title',
            right:  'multiMonthYear,dayGridMonth,listMonth'
        },
        buttonText: {
            today:          "Aujourd'hui",
            year:           'Année',
            month:          'Mois',
            list:           'Liste'
        },
        views: {
            multiMonthYear: { buttonText: 'Année' },
            dayGridMonth:   { buttonText: 'Mois'  },
            listMonth:      { buttonText: 'Liste' },
        },
        selectable:      true,
        selectMinDistance: 0,
        events:          {{ events|json_encode|raw }},
        select: function(info) {
            // L'end FullCalendar est exclusif → on soustrait 1 jour en heure locale
            var p = info.endStr.split('-');
            var endDate = new Date(+p[0], +p[1] - 1, +p[2]);
            endDate.setDate(endDate.getDate() - 1);
            var endStr = endDate.getFullYear() + '-'
                + String(endDate.getMonth() + 1).padStart(2, '0') + '-'
                + String(endDate.getDate()).padStart(2, '0');
            setModalRange(info.startStr, endStr);
            modal.show();
            calendar.unselect();
        },
        eventClick:  function(info) {
            info.jsEvent.preventDefault();
            if (info.event.url) {
                window.location.href = info.event.url;
            }
        },
        eventDidMount: function(info) {
            info.el.title = info.event.title;
        },
        moreLinkText:   function(n) { return '+' + n + ' autre' + (n > 1 ? 's' : ''); },
        height:         'auto',
        fixedWeekCount: false,
    });
    calendar.render();
});
</script>
{% endblock %}
