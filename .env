# .env — Variables d'environnement par défaut (non committées en production)

APP_ENV=dev
APP_SECRET=your_app_secret_here_change_in_production

###> doctrine/doctrine-bundle ###
# MySQL 8
DATABASE_URL="sqlite:///%kernel.project_dir%/var/conges.db"
# PostgreSQL 15 (alternative)
# DATABASE_URL="postgresql://conges:conges@127.0.0.1:5432/conges?serverVersion=15&charset=utf8"
###< doctrine/doctrine-bundle ###
###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=sync://
###< symfony/messenger ###

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/mailer ###
MAILER_DSN=smtp://localhost:1025
MAILER_FROM=conges@collectivite.fr
###< symfony/mailer ###
